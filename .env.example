# SECRET_KEY — JWT signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# ENCRYPTION_KEY — Fernet key for credential encryption
# (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# ENCRYPTION_KEY_OLD — Previous Fernet key, only set during key rotation
ENCRYPTION_KEY_OLD=

# MCP_API_KEY — Bearer token for MCP server authentication
MCP_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://socialmind:socialmind@localhost:5432/socialmind
POSTGRES_PASSWORD=socialmind

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=socialmind
MINIO_SECRET_KEY=socialmind
MINIO_SECURE=false

# LLM Provider (ollama | openai | anthropic | litellm)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Image generation provider (dalle | stability | disabled)
IMAGE_PROVIDER=dalle

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# CAPTCHA solver (2captcha | anticaptcha | capsolver | manual)
CAPTCHA_SOLVER=2captcha
CAPTCHA_API_KEY=

# ChromaDB
CHROMADB_URL=http://localhost:8002

# App
DEBUG=false
LOG_LEVEL=INFO

# Flower monitoring
FLOWER_PASSWORD=flower
